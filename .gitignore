# === Session output files (no data) ===
*.html
*.csv
*.png
*.docx

# === Data (large / subject-specific — do not commit) ===
data/raw/
data/processed/
data/opencap/
data/external/
!data/**/.gitkeep

# === Model artifacts ===
models/trained/
!models/trained/.gitkeep

# === Python ===
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# === Jupyter ===
.ipynb_checkpoints/

# === Arduino / PlatformIO ===
firmware/.pio/
firmware/.vscode/

# === OS junk ===
.DS_Store
Thumbs.db
desktop.ini

# === IDE ===
.idea/
.vscode/
*.swp
*.swo
*.claude

# === API runtime state ===
api_storage/

# === Frontend build artifacts ===
frontend/node_modules/
frontend/dist/
frontend/.vite/

# === Secrets / credentials ===
.env
*.pem
